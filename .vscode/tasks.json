{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cleanup-env",
      "type": "shell",
      "group": "none",
      "dependsOrder": "sequence",
      "dependsOn": [
        "podman-container-remove",
        "podman-image-remove",
        "podman-volume-remove",
        "podman-system-prune",
        "shell-cleanup-folders"
      ]
    },
    {
      "label": "test-application",
      "type": "shell",
      "group": "test",
      "dependsOrder": "sequence",
      "dependsOn": [
        "podman-container-remove",
        "podman-volume-remove",
        "shell-cleanup-folders",
        "podman-compose-env-up",
        "mvn-clean",
        "mvn-package"
      ]
    },
    {
      "label": "start-podman-env",
      "type": "shell",
      "group": "test",
      "dependsOrder": "sequence",
      "dependsOn": [
        "shell-cleanup-folders",
        "podman-compose-env-up",
        "mvn-clean",
        "mvn-compile"
      ]
    },
    {
      "label": "stop-podman-env",
      "type": "shell",
      "group": "test",
      "dependsOrder": "sequence",
      "dependsOn": [
        "podman-compose-env-stop",
        "podman-container-remove",
        "podman-volume-remove",
        "podman-compose-keycloak-export"
      ]
    },
    {
      "label": "shell-cleanup-folders",
      "type": "shell",
      "command": "rm",
      "args": [
        "-rf",
        "bin",
        "logs"
      ],
      "windows": {
        "command": "rmdir",
        "args": [
          "/s",
          "/q",
          "bin",
          "logs"
        ]
      },
      "group": "none"
    },
    {
      "label": "shell-create-folders",
      "type": "shell",
      "command": "mkdir",
      "args": [
        "logs",
        "bin"
      ],
      "group": "none"
    },
    {
      "label": "podman-volume-remove",
      "type": "shell",
      "command": "podman",
      "args": [
        "volume",
        "rm",
        "--force",
        "--all"
      ],
      "group": "none"
    },
    {
      "label": "podman-container-remove",
      "type": "shell",
      "command": "podman",
      "args": [
        "container",
        "rm",
        "--force",
        "--all"
      ],
      "group": "none"
    },
    {
      "label": "podman-image-remove",
      "type": "shell",
      "command": "podman",
      "args": [
        "image",
        "rm",
        "--force",
        "--all"
      ],
      "group": "none"
    },
    {
      "label": "podman-system-prune",
      "type": "shell",
      "command": "podman",
      "args": [
        "system",
        "prune",
        "--force",
        "--all",
        "--volumes"
      ],
      "group": "none"
    },
    {
      "label": "podman-build-image",
      "type": "shell",
      "command": "podman",
      "args": [
        "build",
        "--rm=true",
        "--file",
        "Containerfile",
        "--tag",
        "spring-lessons:latest",
        "."
      ],
      "dependsOrder": "sequence",
      "dependsOn": [
        "mvn-clean",
        "mvn-package-skip-tests"
      ],
      "group": "build"
    },
    {
      "label": "podman-compose-env-up",
      "type": "shell",
      "command": "podman",
      "args": [
        "compose",
        "--project",
        "spring-lessons",
        "--file",
        "./collections/compose-env.yaml",
        "up",
        "--force-recreate",
        "--remove-orphans",
        "--detach"
      ],
      "group": "test"
    },
    {
      "label": "podman-compose-env-stop",
      "type": "shell",
      "command": "podman",
      "args": [
        "compose",
        "--project",
        "spring-lessons",
        "--file",
        "./collections/compose-env.yaml",
        "stop"
      ],
      "group": "test"
    },
    {
      "label": "podman-compose-app-up",
      "type": "shell",
      "command": "podman",
      "args": [
        "compose",
        "--project",
        "spring-lessons",
        "--file",
        "./collections/compose-env.yaml",
        "--file",
        "./collections/compose-app.yaml",
        "up",
        "--force-recreate",
        "--remove-orphans",
        "--detach"
      ],
      "group": "test",
      "dependsOrder": "sequence",
      "dependsOn": [
        "mvn-clean",
        "mvn-package-skip-tests"
      ]
    },
    {
      "label": "podman-compose-app-stop",
      "type": "shell",
      "command": "podman",
      "args": [
        "compose",
        "--project",
        "spring-lessons",
        "--file",
        "./collections/compose-env.yaml",
        "--file",
        "./collections/compose-app.yaml",
        "stop"
      ],
      "group": "test"
    },
    {
      "label": "compile-source-code",
      "type": "shell",
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "mvn-clean",
        "mvn-compile"
      ]
    },
    {
      "label": "mvn-test",
      "type": "shell",
      "command": "mvn",
      "args": [
        "test",
        "--file",
        "pom.xml",
        "--settings",
        "settings.xml"
      ],
      "group": "test"
    },
    {
      "label": "mvn-clean",
      "type": "shell",
      "command": "mvn",
      "args": [
        "clean",
        "--file",
        "pom.xml",
        "--settings",
        "settings.xml"
      ],
      "group": "build"
    },
    {
      "label": "mvn-compile",
      "type": "shell",
      "command": "mvn",
      "args": [
        "compile",
        "--file",
        "pom.xml",
        "--settings",
        "settings.xml"
      ],
      "group": "build"
    },
    {
      "label": "mvn-package",
      "type": "shell",
      "command": "mvn",
      "args": [
        "package",
        "--file",
        "pom.xml",
        "--settings",
        "settings.xml",
        "-Dspring.profiles.active=default,linux"
      ],
      "windows": {
        "command": "mvn",
        "args": [
          "package",
          "--file",
          "pom.xml",
          "--settings",
          "settings.xml",
          "-Dspring.profiles.active=default,windows"
        ]
      },
      "group": "build"
    },
    {
      "label": "mvn-package-skip-tests",
      "type": "shell",
      "command": "mvn",
      "args": [
        "package",
        "--file",
        "pom.xml",
        "--settings",
        "settings.xml",
        "-Dspring.profiles.active=default,linux",
        "-DskipTests=true"
      ],
      "windows": {
        "command": "mvn",
        "args": [
          "package",
          "--file",
          "pom.xml",
          "--settings",
          "settings.xml",
          "-Dspring.profiles.active=default,windows",
          "-DskipTests=true"
        ]
      },
      "group": "build"
    },
    {
      "label": "mvn-dependencies-tree",
      "type": "shell",
      "command": "mvn",
      "args": [
        "dependency:tree",
        "--file",
        "pom.xml",
        "--settings",
        "settings.xml",
        "1>",
        "logs/maven-dependency-tree.log"
      ],
      "windows": {
        "command": "mvn",
        "args": [
          "dependency:tree",
          "--file",
          "pom.xml",
          "--settings",
          "settings.xml",
          ">",
          "logs\\maven-dependency-tree.log"
        ]
      },
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "shell-cleanup-folders",
        "shell-create-folders"
      ]
    },
    {
      "label": "mvn-display-dependency-updates",
      "type": "shell",
      "command": "mvn",
      "args": [
        "versions:display-dependency-updates",
        "--file",
        "pom.xml",
        "--settings",
        "settings.xml",
        "1>",
        "logs/maven-dependency-updates.log"
      ],
      "windows": {
        "command": "mvn",
        "args": [
          "versions:display-dependency-updates",
          "--file",
          "pom.xml",
          "--settings",
          "settings.xml",
          ">",
          "logs\\maven-dependency-updates.log"
        ]
      },
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "shell-cleanup-folders",
        "shell-create-folders"
      ]
    },
    {
      "label": "mvn-display-plugin-updates",
      "type": "shell",
      "command": "mvn",
      "args": [
        "versions:display-plugin-updates",
        "--file",
        "pom.xml",
        "--settings",
        "settings.xml",
        "1>",
        "logs/maven-plugin-updates.log"
      ],
      "windows": {
        "command": "mvn",
        "args": [
          "versions:display-plugin-updates",
          "--file",
          "pom.xml",
          "--settings",
          "settings.xml",
          ">",
          "logs\\maven-plugin-updates.log"
        ]
      },
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "shell-cleanup-folders",
        "shell-create-folders"
      ]
    },
    {
      "label": "mvn-spotless-apply",
      "type": "shell",
      "command": "mvn",
      "args": [
        "spotless:apply",
        "--file",
        "pom.xml",
        "--settings",
        "settings.xml"
      ],
      "group": "build"
    },
    {
      "label": "pre-commit-autoupdate",
      "type": "shell",
      "command": "pre-commit",
      "args": [
        "autoupdate"
      ],
      "group": "none"
    },
    {
      "label": "pre-commit-run-all-files",
      "type": "shell",
      "command": "pre-commit",
      "args": [
        "run",
        "--all-files"
      ],
      "group": "none"
    },
    {
      "label": "podman-compose-keycloak-export",
      "type": "shell",
      "command": "podman",
      "args": [
        "compose",
        "--project",
        "spring-lessons",
        "--file",
        "./collections/compose-keycloak-export.yaml",
        "up",
        "--abort-on-container-exit",
        "--remove-orphans"
      ],
      "group": "none"
    }
  ]
}