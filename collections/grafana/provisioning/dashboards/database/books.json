          "rawSql": "SELECT\n  DATE_TRUNC('day', created_at) :: date AS giorno,\n  COUNT(*) AS totale\nFROM\n  spring_app.books\nWHERE\n  1 = 1\n  AND created_at >= CURRENT_DATE - INTERVAL '30 days'\nGROUP BY\n  DATE_TRUNC('day', created_at) :: date\nORDER BY\n  giorno;",
