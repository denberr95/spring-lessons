# Timezone
TZ=Europe/Rome

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=adminpwd
POSTGRES_DB=spring

# Application debug settings
DEBUG_PORT=5500
RUN_MODE=debug

# Mail credentials (must match mailpit/config/auth_file)
SPRING_MAIL_USERNAME=grafana_sa
SPRING_MAIL_PASSWORD=springapp_password

# Image versions (pin to avoid silent breaking updates)
IMAGE_POSTGRES=18
IMAGE_JAEGER=2.19.0
IMAGE_LOKI=3.7.3
IMAGE_PROMETHEUS=v3.12.0
IMAGE_GRAFANA=13.0.3
IMAGE_OTELCOL=0.155.0
IMAGE_KAFKA=4.3.1
IMAGE_KEYCLOAK=26.6
IMAGE_WIREMOCK=3x
IMAGE_MAILPIT=v1.30
