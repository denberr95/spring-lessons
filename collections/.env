# Timezone
TZ=Europe/Rome

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=adminpwd
POSTGRES_DB=spring

# Application debug settings
DEBUG_PORT=5500
RUN_MODE=debug

# Mail credentials (must match mailpit/config/auth_file)
SPRING_MAIL_USERNAME=springapp_sa
SPRING_MAIL_PASSWORD=springapp_password

# Image versions (pin to avoid silent breaking updates)
IMAGE_POSTGRES=18.4
IMAGE_JAEGER=2.19.0
IMAGE_LOKI=3.7.3
IMAGE_PROMETHEUS=v3.13.1
IMAGE_GRAFANA=13.1.0
IMAGE_OTELCOL=0.156.0
IMAGE_KAFKA=4.3.1
IMAGE_KEYCLOAK=26.7.0
IMAGE_WIREMOCK=3.13.2
IMAGE_MAILPIT=v1.30.4
IMAGE_JRE=25.0.3
